{
  "name": "cap2ui5-builder",
  "version": "1.0.0",
  "private": true,
  "description": "Builder project for cap2UI5 — the ABAP→JS transpiler, sync scripts and jest suite that mirror upstream abap2UI5 and generate the deployable CAP project in ../cap2UI5",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "jest --config jest.config.js --verbose",
    "test:watch": "jest --config jest.config.js --watch",
    "transpile": "node scripts/abap2js.js",
    "mirror_abap2ui5": "node scripts/mirror-input.js abap2UI5",
    "mirror_app": "node scripts/mirror-input.js app",
    "mirror_samples": "node scripts/mirror-input.js samples",
    "transpile_abap2ui5": "node scripts/transpile-tree.js abap2UI5",
    "transpile_samples": "node scripts/transpile-tree.js samples",
    "prepare_app": "node scripts/prepare-app.js",
    "copy_abap2ui5": "node scripts/copy-into-cap.js abap2UI5",
    "copy_app": "node scripts/copy-into-cap.js app",
    "copy_samples": "node scripts/copy-into-cap.js samples",
    "copy_into_cap": "node scripts/copy-into-cap.js",
    "snapshot_base": "node scripts/snapshot-base.js"
  },
  "devDependencies": {
    "@abaplint/core": "^2.119.56",
    "jest": "^30.2.0"
  }
}
