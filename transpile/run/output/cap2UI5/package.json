{
  "name": "cap2ui5",
  "version": "1.0.0",
  "description": "cap2UI5 \u2014 the abap2UI5 concept on CAP/Node.js: the full CAP app built on the platform-neutral abap2UI5 core package. Fully auto-generated (AI + sync pipeline).",
  "repository": "github:cap2UI5/cap2UI5",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@sap/cds": "^10",
    "abap2UI5": "file:../core",
    "express": "^5"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/cds-types": "^0.18",
    "@cap-js/sqlite": "^3",
    "@sap/cds-dk": "^10",
    "jest": "^30",
    "mbt": "^1.2.34",
    "rimraf": "^6"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "watch-z2ui5": "cds watch --open z2ui5/webapp/index.html?sap-ui-xx-viewCache=false",
    "test": "jest",
    "undeploy": "cf undeploy cap2UI5 --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "cds": {
    "requires": {
      "northwind": {
        "kind": "odata-v2",
        "model": "srv/external/northwind",
        "credentials": {
          "url": "https://services.odata.org/V2/Northwind/Northwind.svc/"
        }
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true,
      "[production]": {
        "auth": false
      }
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/test/**/*.test.js"
    ]
  }
}
