{
  "name": "cap2UI5",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "npm install --prefix cap2UI5 && npm install --prefix builder",
  "forwardPorts": [4004],
  "portsAttributes": {
    "4004": {
      "label": "cds server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["SAPSE.vscode-cds"]
    }
  }
}
